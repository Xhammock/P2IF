{
  "seed": 42,
  "data": {
    "root": "data/weekday",
    "feature_file": "features.csv",
    "spatial_adj": "Spatial_Adjacency/adjacency_matrix.csv",
    "spatial_ids": "Spatial_Adjacency/adjacency_ids.txt",
    "od_matrix": "OD_Aajacency/Flow_matrix_weekday.csv",
    "hops_matrix_path": "data/weekday/Spatial_Adjacency/hops_matrix.csv",
    "od_edgelist": null,
    "top_k_od": null,
    "use_street": false,
    "dims": {
      "poi": 155,
      "res": 28,
      "vis": 28,
      "street": 0
    }
  },
  "model": {
    "hidden_dim": 256,
    "sage_layers": 2,
    "n_heads": 4,
    "dropout": 0.1,
    "proj_dim": 128,
    "spatial_lambda": 0.1,
    "loss_eps": 1e-15,
    "hops_threshold": 5,
    "loss_type": "divreg"
  },
  "optim": {
    "lr": 0.0001,
    "weight_decay": 0.0,
    "scheduler": {
      "type": "CosineAnnealingLR",
      "min_lr": 1e-06,
      "step_size": 100,
      "gamma": 0.5
    }
  },
  "train": {
    "epochs": 300,
    "save_every": 10,
    "patience": null,
    "out_dir": "checkpoints"
  }
}
