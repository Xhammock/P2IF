{
  "seed": 42,
  "data": {
    "root": "data/weekday",
    "feature_file": "features.csv",
    "spatial_adj": "Spatial_Adjacency/adjacency_matrix.csv",
    "spatial_ids": "Spatial_Adjacency/adjacency_ids.txt",
    "od_matrix": "OD_Aajacency/Flow_matrix_weekday.csv",
    "od_edgelist": null,
    "top_k_od": null,
    "use_street": false,
    "dims": {
      "poi": 155,
      "res": 28,
      "vis": 28,
      "street": 0
    }
  },
  "model": {
    "model_type": "hrep",
    "embedding_size": 144,
    "gcn_layers": 3,
    "dropout": 0.1,
    "importance_k": 10,
    "proj_dim": 128
  },
  "optim": {
    "lr": 0.001,
    "weight_decay": 0.005,
    "scheduler": {
      "type": "CosineAnnealingLR",
      "min_lr": 1e-06,
      "step_size": 100,
      "gamma": 0.5
    }
  },
  "train": {
    "epochs": 300,
    "save_every": 10,
    "patience": null,
    "out_dir": "checkpoints"
  }
}
